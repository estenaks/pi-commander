# ---------------------------------------------------------------
# pi-commander environment config — copy to .env and fill in.
# See README for full setup instructions.
# ---------------------------------------------------------------

# ---- Wi-Fi ----
# Used by the Pi's network configuration (e.g. wpa_supplicant), not by app.py.
# Do not quote values — the simple .env parser reads everything after "=" literally.
WIFI_SSID=your_network_name
WIFI_PASSWORD=your_wifi_password

# ---- Webserver binding ----
# Use 127.0.0.1 when behind nginx, 0.0.0.0 for direct access
HOST=127.0.0.1
PORT=8000

# ---- DEV_PORT suffix ----
# Appended to URLs in templates and QR codes.
# Leave as ":8000" for dev / no-nginx setups.
# Change to (empty string) when nginx handles port 80 in production.
DEV_PORT=:8000
# DEV_PORT=
